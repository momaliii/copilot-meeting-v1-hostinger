# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Secret key for signing JWT tokens.
# Change this to a strong random string in production.
JWT_SECRET="change-me-to-a-strong-random-secret"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# Optional: Set to "true" when behind a reverse proxy (nginx, Cloudflare, etc.).
# Enables correct client IP from X-Forwarded-For for rate limiting and security.
# TRUST_PROXY="true"

# Optional: Security events retention in days (default 90). Older events are purged hourly.
# SECURITY_EVENTS_RETENTION_DAYS="90"

# Optional: Auto-block IP after N suspicious pattern hits in 15 min (default 5).
# SUSPICIOUS_AUTO_BLOCK_THRESHOLD="5"

# Optional: Account lockout parameters.
# LOCKOUT_MAX_ATTEMPTS="5"
# LOCKOUT_WINDOW_MINUTES="15"
# LOCKOUT_DURATION_MINUTES="30"

# Optional: IP-based login lockout (failed attempts from same IP).
# IP_LOCKOUT_THRESHOLD="20"
# IP_AUTO_BLOCK_THRESHOLD="50"

# Optional: Admin IP allowlist. When set, only these IPs can access admin (comma-separated, CIDR supported).
# ADMIN_ALLOWED_IPS="192.168.1.100,10.0.0.0/8"

# Optional: Block requests with empty User-Agent (default false). May block legitimate API clients.
# BLOCK_EMPTY_USER_AGENT="true"

# Optional: Block known bot User-Agents e.g. curl, wget, python-requests (default false).
# BLOCK_BOT_USER_AGENTS="true"

# Optional: Security alert webhook. POST when suspicious_pattern/blocked_request spike (e.g. 10 in 5 min).
# SECURITY_ALERT_WEBHOOK="https://hooks.slack.com/..."
# SECURITY_ALERT_THRESHOLD="10"
# SECURITY_ALERT_WINDOW_MINUTES="5"

# Optional: Multi-instance blocklist sync. Reload blocked_ips from DB every N seconds (0=disabled).
# BLOCKLIST_SYNC_INTERVAL_SEC="60"

# DATABASE_URL: Supabase Postgres connection string (required for production).
# From Supabase Dashboard: Project Settings > Database > Connection string (URI).
# Use "Transaction" or "Session" pooler for server-side connections.
# For local dev with SQLite, leave unset or use a local Postgres URL.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Optional: Use SQLite for local dev when DATABASE_URL is not set.
# Set to "true" to use app.db (SQLite) instead of Postgres.
USE_SQLITE_FOR_DEV="false"

# Optional: Google OAuth 2.0 credentials for Google Meet and Gmail integration.
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API, Gmail API
# Add gmail.send scope to OAuth consent screen
# Set redirect URI to: {APP_URL}/api/google/auth/callback
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: SMTP for verification emails and meeting follow-up emails.
# Used when sending from app address (e.g. noreply@yoursite.com). Rate limits configurable in Admin > Branding.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="noreply@meetingcopilot.app"
# SMTP_SECURE="false"

# Optional: Deepgram API key for server-side streaming live transcript.
# When set, provides higher-quality real-time transcription (falls back to Web Speech API when unset).
# DEEPGRAM_API_KEY="your-deepgram-api-key"

# Optional fallback cost for all plans (legacy).
ADMIN_COST_PER_MINUTE="0.0025"

# Plan-specific processing/inference costs per meeting minute.
# These are used by admin financial analytics (cost, profit, margin).
ADMIN_COST_PER_MINUTE_STARTER="0.0020"
ADMIN_COST_PER_MINUTE_PRO="0.0035"
